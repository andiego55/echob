# EchoB API – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Niemals .env in Git einchecken.

# ── Meta ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=info

# ── CORS ──────────────────────────────────────────────────────────────────
# Kommagetrennt, kein Leerzeichen
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Sicherheit ────────────────────────────────────────────────────────────
# Langen Zufallsstring generieren: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# ── Supabase (ab Phase 1) ─────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Datenbank direkt (optional, alternativ zu Supabase SDK) ───────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/echob

# ── AI (ab Phase 3) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-key
