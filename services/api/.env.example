# EchoB API – Umgebungsvariablen
# Kopiere diese Datei nach .env und fülle die Werte aus.

# Umgebung
ENVIRONMENT=development

# Supabase (ab Phase 1)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Datenbank direkt (optional, alternativ zu Supabase SDK)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/echob

# AI-Provider (ab Phase 3)
ANTHROPIC_API_KEY=your-anthropic-key

# CORS (kommagetrennte Origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Secret für interne Signierung (generiere einen langen Zufallsstring)
SECRET_KEY=change-me-in-production
