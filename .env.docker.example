# EchoB – Docker-Compose Umgebungsvariablen
# Kopiere diese Datei nach .env.docker und passe sie an.
# Wird von docker-compose.yml über env_file: .env.docker geladen.

# ── Postgres (lokale Dev-Datenbank) ───────────────────────────────────────
POSTGRES_DB=echob
POSTGRES_USER=echob_dev
POSTGRES_PASSWORD=pgadmin

# ── API ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=debug

# Im Docker-Netzwerk ist der Hostname der Service-Name ("postgres")
DATABASE_URL=postgresql+asyncpg://echob_dev:pgadmin@postgres:5432/echob

# CORS: JSON-Array (pydantic-settings v2 erwartet dieses Format für list[str])
# In docker-compose.yml bereits gesetzt – hier nur bei Bedarf überschreiben:
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:8080"]

SECRET_KEY=local-dev-secret-not-for-production

# Supabase – leer lassen für rein lokale Entwicklung
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI – optional für lokale Tests
ANTHROPIC_API_KEY=

# ── pgAdmin (optional, --profile tools) ───────────────────────────────────
PGADMIN_EMAIL=dev@echob.dev
PGADMIN_PASSWORD=pgadmin

# ── Worker ────────────────────────────────────────────────────────────────
# Erbt DATABASE_URL und ANTHROPIC_API_KEY von oben
