# ── EchoB Production-Umgebung ────────────────────────────────────────────────
# Auf dem Server nach .env.docker kopieren und ALLE Werte ausfüllen:
#   cp .env.production.example .env.docker
#
# Secrets erzeugen:
#   SECRET_KEY:        openssl rand -hex 32
#   POSTGRES_PASSWORD: openssl rand -base64 24   (auch in DATABASE_URL eintragen!)

# ── Meta ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=production
SECRET_KEY=

# ── Datenbank ────────────────────────────────────────────────────────────────
POSTGRES_DB=echob
POSTGRES_USER=echob
POSTGRES_PASSWORD=
# Gleiche Werte wie oben (Host "postgres" = Compose-Servicename):
DATABASE_URL=postgresql+asyncpg://echob:DEIN_POSTGRES_PASSWORD@postgres:5432/echob

# ── CORS / Frontend ──────────────────────────────────────────────────────────
# Achtung: über Dockers env_file MUSS das JSON-Array-Format verwendet werden
# (pydantic-settings parst Listen-Felder aus Env-Vars als JSON):
CORS_ORIGINS=["https://echo-b.de","https://www.echo-b.de"]
FRONTEND_URL=https://echo-b.de

# ── Supabase (Auth) ──────────────────────────────────────────────────────────
SUPABASE_URL=https://pfwvlnykucmpbptnyzjm.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ── Stripe (Zahlungen) ───────────────────────────────────────────────────────
# Live-Keys aus https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Signing Secret des Webhook-Endpoints (https://api.echo-b.de/api/v1/subscription/webhook)
STRIPE_WEBHOOK_SECRET=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info
